rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    match /users/{userId} {
      allow read, delete: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId && isValidUserDoc(request.resource.data);
      
      match /transactions/{txId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null && request.auth.uid == userId && isValidTransaction(request.resource.data);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// ── Helpers ─────────────────────────────────────────────────────────────────

function isValidUserDoc(data) {
  return 
    data.keys().hasOnly(['monthlyIncome', 'monthlyBudget', 'onboardingComplete', 'updatedAt', 'income', 'savings']) &&
    (!('monthlyIncome' in data) || (data.monthlyIncome is number && data.monthlyIncome >= 0 && data.monthlyIncome <= 100000000)) &&
    (!('monthlyBudget' in data) || (data.monthlyBudget is number && data.monthlyBudget >= 0 && data.monthlyBudget <= 100000000)) &&
    (!('income' in data) || (data.income is number && data.income >= 0 && data.income <= 100000000)) &&
    (!('savings' in data) || (data.savings is number && data.savings >= 0 && data.savings <= 100000000)) &&
    (!('onboardingComplete' in data) || data.onboardingComplete is bool) &&
    (!('updatedAt' in data) || data.updatedAt is string);
}

function isValidTransaction(data) {
  return
    data.keys().hasOnly(['id', 'amount', 'category', 'date', 'note', 'payMode', 'type', 'createdAt']) &&
    data.amount is number &&
    data.amount > 0 &&
    data.amount <= 100000000 &&
    data.category is string &&
    data.date is string &&
    data.type in ['income', 'expense'] &&
    (!('id' in data) || data.id is string) &&
    (!('note' in data) || (data.note is string && data.note.size() <= 200)) &&
    (!('payMode' in data) || data.payMode is string) &&
    (!('createdAt' in data) || data.createdAt is string);
}
