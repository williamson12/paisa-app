rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User data: only the authenticated owner can read/write ──────────────
    match /appData/{userId} {

      allow read, delete: if
        // Must be signed in
        request.auth != null &&
        // Must be the document owner
        request.auth.uid == userId;

      // ── Write validation (create & update) ─────────────────────────────
      allow create, update: if
        request.auth != null &&
        request.auth.uid == userId &&
        isValidAppData(request.resource.data);
    }

    // Onboarding/profile flags: only the authenticated owner can read/write.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create, update: if
        request.auth != null &&
        request.auth.uid == userId &&
        isValidUserProfile(request.resource.data);
    }

    // ── Deny everything else by default ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// ── Helpers ─────────────────────────────────────────────────────────────────
function isValidAppData(data) {
  return
    // Required top-level fields
    data.keys().hasAll(['monthlyIncome', 'monthlyBudget', 'transactions']) &&

    // Type checks
    data.monthlyIncome  is number &&
    data.monthlyBudget  is number &&
    data.transactions   is list   &&

    // Sane value ranges
    data.monthlyIncome  >= 0 &&
    data.monthlyIncome  <= 100000000 &&
    data.monthlyBudget  >= 0 &&
    data.monthlyBudget  <= 100000000 &&

    // Transaction list size guard (max 5000 entries)
    data.transactions.size() <= 5000;
}

function isValidUserProfile(data) {
  return
    data.keys().hasOnly(['income', 'savings', 'onboardingComplete', 'updatedAt']) &&
    (!('income' in data) || (data.income is number && data.income >= 0 && data.income <= 100000000)) &&
    (!('savings' in data) || (data.savings is number && data.savings >= 0 && data.savings <= 100000000)) &&
    (!('onboardingComplete' in data) || data.onboardingComplete is bool) &&
    (!('updatedAt' in data) || data.updatedAt is string);
}
