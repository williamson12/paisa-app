# ─── Firebase (safe to expose — restricted by Firebase security rules) ───
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── Gemini — SERVER ONLY (Netlify env var, NEVER prefix with VITE_) ───
# Set this in Netlify Dashboard → Site Settings → Environment Variables
# NEVER commit the real value here or in .env
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional: lock CORS to your production domain ───
ALLOWED_ORIGIN=https://yourapp.netlify.app
